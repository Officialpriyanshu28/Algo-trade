{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile photo URL." },
        "watchlist": { "type": "array", "items": { "type": "string" }, "description": "List of coin IDs the user is tracking." },
        "lastLogin": { "type": "string", "format": "date-time", "description": "The last time the user logged in." }
      },
      "required": ["uid", "email"]
    },
    "Strategy": {
      "title": "Trading Strategy",
      "description": "Defines a sequence of blocks for a trading algorithm.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns the strategy." },
        "name": { "type": "string", "description": "The name of the strategy." },
        "blocks": { "type": "array", "description": "The sequence of strategy blocks." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the strategy was created." }
      },
      "required": ["userId", "name", "blocks"]
    },
    "BrokerConnection": {
      "title": "Broker Connection",
      "description": "Stores API keys for exchange connections.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns the connection." },
        "exchange": { "type": "string", "enum": ["Binance", "Coinbase Pro", "Kraken", "Bybit"], "description": "The exchange name." },
        "apiKey": { "type": "string", "description": "The API key." },
        "apiSecret": { "type": "string", "description": "The API secret." },
        "status": { "type": "string", "description": "The connection status." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the connection was added." }
      },
      "required": ["userId", "exchange", "apiKey", "apiSecret"]
    },
    "PublicProfile": {
      "title": "Public Profile",
      "description": "Non-sensitive user information shared with the community.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's ID." },
        "displayName": { "type": "string", "description": "The user's public name." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's public photo." },
        "lastSeen": { "type": "string", "format": "date-time", "description": "Last activity timestamp." }
      },
      "required": ["uid", "displayName"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/strategies/{strategyId}": {
      "schema": "Strategy",
      "description": "Collection of trading strategies."
    },
    "/broker_connections/{connectionId}": {
      "schema": "BrokerConnection",
      "description": "Collection of broker API connections."
    },
    "/public_profiles/{userId}": {
      "schema": "PublicProfile",
      "description": "Collection of public user profiles."
    }
  }
}
